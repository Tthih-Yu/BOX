# 复制为 material-pull.env 后按需修改：
# cp material-pull.env.example material-pull.env

# 项目根目录（一般不用改）
PROJECT_ROOT=/home/wan/IE

# 运行用户（install-autostart.sh 会自动写入当前用户）
RUN_USER=wan

# Java 17 路径
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# 后端配置
SPRING_PROFILE=dev
BACKEND_JAR=material-pull-system-backend-0.8.4.jar
# Android 扫码设备密钥；APP 设置页填写同一个值后可不登录直接扫码
MATERIAL_PULL_EXTERNAL_API_KEY=MaterialPullDeviceKey2026

# 首次部署保留；管理员创建成功后建议注释或删除
MATERIAL_PULL_BOOTSTRAP_ADMIN_PASSWORD=Admin123456

# 前端 dev:lan 允许局域网访问；dev 仅本机
FRONTEND_MODE=dev:lan

# 日志与 PID 目录（手动 start.sh 使用）
LOG_DIR=/home/wan/IE/logs
PID_DIR=/home/wan/IE/.run

# 公网映射（SSH 反向隧道到阿里云）
TUNNEL_REMOTE_HOST=47.103.94.109
TUNNEL_REMOTE_USER=root
TUNNEL_SSH_KEY=/home/wan/.ssh/aliyun_key.pem
TUNNEL_LOCAL_PORT=8888
TUNNEL_REMOTE_PORT=18080
TUNNEL_LOG_FILE=/home/wan/.ssh/tunnel.log
